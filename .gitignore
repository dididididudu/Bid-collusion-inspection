# ============================================================
# .gitignore — 围标串标检测系统
# ============================================================

# ── Python 编译产物 ─────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── 虚拟环境 / 包管理 ────────────────────────────────────────
venv/
.env/
.venv/
ENV/
env/
build/
dist/
*.egg-info/
*.egg
.eggs/
.Python
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
.installed.cfg

# ── IDE / 编辑器 ────────────────────────────────────────────
.idea/
.vscode/
.trae/
*.swp
*.swo
*~
.claude/

# ── 操作系统 ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── 敏感配置（包含密钥/密码，不入仓）─────────────────────────
.env
config.json

# ── 模型文件（大文件，离线下载）──────────────────────────────
models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt
*.onnx

# ── 日志 ────────────────────────────────────────────────────
*.log

# ── 运行时产物（下载缓存 / 工作目录 / 检查点）────────────────
batch_downloads/
collusive_workdir/
cache/
workdir/
checkpoints/
cache_old_*/
checkpoints_old*/
runtime/

# ── 测试产物 ────────────────────────────────────────────────
test_output/
.pytest_cache/
.coverage
htmlcov/
test_data/

# ── 报告 / 输出 ─────────────────────────────────────────────
output/
report/
results/
input/
input1/

# ── 压缩包 / 构建产物 ───────────────────────────────────────
*.zip
*.tar.gz
*.whl

# ── 临时文件 ────────────────────────────────────────────────
*.tmp
*.bak
*.backup

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
batch_downloads/
