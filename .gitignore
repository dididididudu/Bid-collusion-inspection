# .gitignore for BatchBidCollusionDetector

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
cache/

# 测试和报告
test_data/
*.log
detection.log
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 临时文件
*.tmp
*.bak
*.backup

# 输出文件
report/
output/
results/

# 配置文件（可能包含敏感信息）
config.json

# 深度学习模型文件（大文件，排除上传）
models/
*.safetensors
*.bin
*.pt
*.pth
*.ckpt

# 输入数据（投标文件PDF等测试数据，大文件不应入仓）
input/

# 旧的缓存和检查点（运行产物，不应入仓）
cache_old_*/
checkpoints_old/

# IDE配置
.claude/

# Jupyter Notebook
.ipynb_checkpoints

# 系统文件
Thumbs.db
desktop.ini
