{
  "_comment": "GPU 生产配置 — CUDA 12.1 + PaddleOCR 3.x (PP-OCRv6) + GPU 加速",

  "TEXT_GLOBAL_THRESHOLD": 0.80,
  "TEXT_LOCAL_THRESHOLD": 0.85,

  "USE_GPU": true,
  "SBERT_DEVICE": "cuda",
  "SBERT_BATCH_SIZE": 256,

  "MAX_WORKERS": 8,
  "PHASE1_WORKERS": 4,
  "PHASE3_WORKERS": 4,
  "EMBED_WORKERS": 4,
  "CHUNK_PAGE_SIZE": 50,
  "MAX_MEMORY_MB": 8192,
  "DB_BUSY_TIMEOUT": 60000,

  "ENABLE_OCR": true,
  "OCR_ENGINE": "paddleocr",
  "OCR_LANGUAGES": ["ch_sim", "en"],
  "OCR_MIN_CONFIDENCE": 0.3,
  "OCR_MODEL_DIR": "./models/ocr",
  "OCR_OFFLINE_MODE": true,
  "PADDLEOCR_HOME": "./models/ocr",
  "OCR_RETRY_COUNT": 3,

  "IMAGE_MIN_SIZE": 50,
  "BID_BOILERPLATE_FILTER": true,
  "BID_BOILERPLATE_WEIGHT": 0.3,

  "MINHASH_BANDS": 8,
  "MINHASH_ROWS": 4,
  "MINHASH_NUM_HASHES_PARAGRAPH": 32,
  "PARAGRAPH_MIN_JACCARD": 0.05,

  "ENABLE_EMBEDDING_CACHE": true,
  "DOC_VECTOR_FILTER_ENABLED": true,
  "METADATA_FILTER_ENABLED": true,
  "ENABLE_CHECKPOINT": true,
  "DISABLE_CACHE": false
}
